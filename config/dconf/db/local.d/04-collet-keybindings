# Collet OS — Custom Keyboard Shortcuts
# Binds Super+Space to the command palette.
# Users can override via Settings > Keyboard > Shortcuts.

# Disable GNOME's default Super+Space (input source switching)
[org/gnome/desktop/wm/keybindings]
switch-input-source=@as []
switch-input-source-backward=@as []

# Register custom shortcut for the command palette
[org/gnome/settings-daemon/plugins/media-keys]
custom-keybindings=['/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/collet-palette/']

[org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/collet-palette]
name='Command Palette'
command='collet-palette'
binding='<Super>space'
