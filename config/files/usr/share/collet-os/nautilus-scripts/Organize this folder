#!/usr/bin/env bash
# Collet OS — AI-powered folder organization
set -euo pipefail

OLLAMA_HOST="${OLLAMA_HOST:-http://localhost:11434}"
OLLAMA_MODEL="${OLLAMA_MODEL:-llama3.2:3b}"
AUDIT_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/collet-os/audit"
mkdir -p "$AUDIT_DIR"

# Get current directory (URL-decode the URI)
dir="${NAUTILUS_SCRIPT_CURRENT_URI#file://}"
dir="$(python3 -c "import urllib.parse,sys; print(urllib.parse.unquote(sys.argv[1]))" "$dir" 2>/dev/null || echo "$dir")"

[[ -z "$dir" || ! -d "$dir" ]] && exit 0

# List files (not directories) in the folder
listing="$(find "$dir" -maxdepth 1 -type f -printf '%f\n' 2>/dev/null | sort | head -200)"
file_count="$(echo "$listing" | wc -l)"

[[ "$file_count" -lt 2 ]] && {
    zenity --info --text="This folder has fewer than 2 files. Nothing to organize." --title="Organize" 2>/dev/null
    exit 0
}

# Ask AI for organization plan
plan="$(curl -sS --max-time 120 "$OLLAMA_HOST/v1/chat/completions" \
    -H "Content-Type: application/json" \
    -d "$(jq -n \
        --arg m "$OLLAMA_MODEL" \
        --arg files "$listing" \
        --arg count "$file_count" \
        '{model:$m, messages:[
            {role:"system",content:"You are a file organization assistant. Given a list of filenames, suggest how to organize them into folders by type. Output ONLY a bash script using mkdir -p and mv commands. Use simple, clear folder names (Images, Documents, Audio, Video, Archives, Code). No explanations, just the script. Do not use rm or delete commands."},
            {role:"user",content:($count + " files to organize:\n" + $files)}
        ], temperature:0.2, max_tokens:500}')" \
    2>/dev/null | jq -r '.choices[0].message.content // "No response."')"

# Strip markdown code fences if present
plan="$(echo "$plan" | sed 's/^```[a-z]*//;s/^```//;/^$/d')"

# Show plan and ask for confirmation
response="$(zenity --text-info \
    --title="Organize: $(basename "$dir") ($file_count files)" \
    --width=700 --height=500 \
    --filename=<(printf "Proposed organization for %s:\n\n%s" "$dir" "$plan") \
    --checkbox="I have reviewed the plan and want to execute it" 2>&1)" || exit 0

# Only proceed if checkbox was checked
if echo "$response" | grep -qi "true"; then
    # Extract ONLY mkdir and mv commands for safety
    safe_commands="$(echo "$plan" | grep -E '^\s*(mkdir|mv)\s' || true)"

    if [[ -z "$safe_commands" ]]; then
        zenity --warning --text="No valid mkdir/mv commands found in the plan." --title="Organize" 2>/dev/null
        exit 0
    fi

    # Audit
    printf '%s | FOLDER_ORGANIZE | %s | %d files\n' "$(date -Iseconds)" "$dir" "$file_count" >> "$AUDIT_DIR/actions.log"

    # Execute
    cd "$dir"
    result="$(bash -e <<< "$safe_commands" 2>&1)" || true

    zenity --info \
        --text="Folder organized. $file_count files processed." \
        --title="Done" 2>/dev/null
fi
