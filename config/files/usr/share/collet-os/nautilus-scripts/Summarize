#!/usr/bin/env bash
# Collet OS — Summarize file(s) with AI
set -euo pipefail

OLLAMA_HOST="${OLLAMA_HOST:-http://localhost:11434}"
OLLAMA_MODEL="${OLLAMA_MODEL:-llama3.2:3b}"
AUDIT_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/collet-os/audit"
mkdir -p "$AUDIT_DIR"

IFS=$'\n' read -r -d '' -a FILES <<< "${NAUTILUS_SCRIPT_SELECTED_FILE_PATHS:-}" || true
[[ ${#FILES[@]} -eq 0 ]] && exit 0

for file in "${FILES[@]}"; do
    [[ -z "$file" || ! -f "$file" ]] && continue

    filename="$(basename "$file")"
    mime="$(file --brief --mime-type "$file")"

    # Extract readable content based on type
    case "$mime" in
        text/*|application/json|application/xml|application/javascript|application/x-shellscript)
            content="$(head -c 40000 "$file")"
            ;;
        application/pdf)
            if command -v pdftotext &>/dev/null; then
                content="$(pdftotext "$file" - 2>/dev/null | head -c 40000)"
            else
                zenity --info --text="PDF support requires poppler-utils." --title="Summarize" 2>/dev/null
                continue
            fi
            ;;
        *)
            zenity --info --text="Cannot summarize: $mime" --title="Summarize" 2>/dev/null
            continue
            ;;
    esac

    # Call AI
    summary="$(curl -sS --max-time 120 "$OLLAMA_HOST/v1/chat/completions" \
        -H "Content-Type: application/json" \
        -d "$(jq -n \
            --arg m "$OLLAMA_MODEL" \
            --arg c "$content" \
            '{model:$m, messages:[
                {role:"system",content:"Summarize the following document concisely. Use bullet points for key findings. Respond in the same language as the document."},
                {role:"user",content:$c}
            ], temperature:0.2, max_tokens:500}')" \
        2>/dev/null | jq -r '.choices[0].message.content // "No response from AI."')"

    # Audit
    printf '%s | FILE_SUMMARIZE | %s | %s\n' "$(date -Iseconds)" "$file" "$mime" >> "$AUDIT_DIR/actions.log"

    # Display
    zenity --text-info \
        --title="Summary: $filename" \
        --width=640 --height=480 \
        --font="Geist 12" \
        --filename=<(echo "$summary") 2>/dev/null
done
