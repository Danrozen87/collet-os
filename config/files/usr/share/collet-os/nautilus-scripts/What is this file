#!/usr/bin/env bash
# Collet OS — AI-powered file identification
set -euo pipefail

OLLAMA_HOST="${OLLAMA_HOST:-http://localhost:11434}"
OLLAMA_MODEL="${OLLAMA_MODEL:-llama3.2:3b}"
AUDIT_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/collet-os/audit"
mkdir -p "$AUDIT_DIR"

IFS=$'\n' read -r -d '' -a FILES <<< "${NAUTILUS_SCRIPT_SELECTED_FILE_PATHS:-}" || true
[[ ${#FILES[@]} -eq 0 ]] && exit 0

file="${FILES[0]}"
[[ -z "$file" ]] && exit 0

filename="$(basename "$file")"
mime="$(file --brief --mime-type "$file")"
details="$(file --brief "$file")"
size_bytes="$(stat --printf='%s' "$file" 2>/dev/null || stat -f '%z' "$file" 2>/dev/null || echo 'unknown')"

# Human-readable size
if [[ "$size_bytes" =~ ^[0-9]+$ ]]; then
    if (( size_bytes > 1073741824 )); then
        size="$(echo "scale=1; $size_bytes/1073741824" | bc) GB"
    elif (( size_bytes > 1048576 )); then
        size="$(echo "scale=1; $size_bytes/1048576" | bc) MB"
    elif (( size_bytes > 1024 )); then
        size="$(echo "scale=1; $size_bytes/1024" | bc) KB"
    else
        size="$size_bytes bytes"
    fi
else
    size="$size_bytes"
fi

# Build info
info="Name: $filename
Type: $mime
Size: $size
Details: $details"

# Ask AI for deeper analysis if available
if curl -sf --max-time 3 "$OLLAMA_HOST/api/tags" >/dev/null 2>&1; then
    snippet="$(head -c 8000 "$file" 2>/dev/null | strings | head -c 4000 || echo '[binary]')"

    ai_desc="$(curl -sS --max-time 60 "$OLLAMA_HOST/v1/chat/completions" \
        -H "Content-Type: application/json" \
        -d "$(jq -n \
            --arg m "$OLLAMA_MODEL" \
            --arg fn "$filename" \
            --arg mt "$mime" \
            --arg sn "$snippet" \
            '{model:$m, messages:[
                {role:"system",content:"Describe what this file is and its likely purpose in 2-3 sentences. Be specific. Respond in the users language."},
                {role:"user",content:("Filename: " + $fn + "\nMIME: " + $mt + "\nContent preview:\n" + $sn)}
            ], temperature:0.2, max_tokens:200}')" \
        2>/dev/null | jq -r '.choices[0].message.content // ""')"

    [[ -n "$ai_desc" ]] && info="$info

$ai_desc"
fi

# Audit
printf '%s | FILE_IDENTIFY | %s | %s\n' "$(date -Iseconds)" "$file" "$mime" >> "$AUDIT_DIR/actions.log"

zenity --text-info \
    --title="$filename" \
    --width=560 --height=360 \
    --filename=<(echo "$info") 2>/dev/null
