# Collet OS — GNOME Appearance Defaults
# Color language derived from Collet Design System (OKLCH)
# Light: warm muted tones (hue 90, low chroma 0.003-0.005)
# Dark: pure neutral greys (zero chroma, proper elevation stack)
# Users can override all of these through Settings.

[org/gnome/desktop/interface]
color-scheme='prefer-dark'
gtk-theme='adw-gtk3-dark'
icon-theme='WhiteSur'
font-name='Geist 11'
document-font-name='Geist 11'
monospace-font-name='Geist Mono 10'
clock-format='24h'
clock-show-weekday=true
enable-animations=true
accent-color='slate'

[org/gnome/desktop/background]
picture-uri='file:///usr/share/backgrounds/collet/default.png'
picture-uri-dark='file:///usr/share/backgrounds/collet/default-dark.png'
picture-options='zoom'

[org/gnome/desktop/screensaver]
picture-uri='file:///usr/share/backgrounds/collet/default-dark.png'

[org/gnome/desktop/wm/preferences]
button-layout='appmenu:minimize,maximize,close'
action-double-click-titlebar='toggle-maximize'
action-middle-click-titlebar='none'
titlebar-font='Geist Medium 11'

[org/gnome/mutter]
center-new-windows=true
